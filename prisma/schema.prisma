generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

enum Gender {
  male
  female
}

enum TrainingIntensity {
  low
  medium
  high
}

enum CarbType {
  high
  mid
  low
}

enum ChatRole {
  user
  ai
}

model User {
  id                String            @id @default(cuid())
  name              String
  gender            Gender
  age               Int
  height            Float
  weight            Float
  bodyFat           Float
  trainingFrequency Int
  trainingIntensity TrainingIntensity
  startDate         DateTime
  initialWeightDate DateTime?         @db.Date
  goalWeight        Float
  somatotype        String            @default("mesomorph")
  trainingSchedule  Json?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  dayPlans          DayPlan[]
  chatMessages      ChatMessage[]
  weightEntries     WeightEntry[]
  mealLogs          MealLog[]
  dailyReports      DailyReport[]
  weeklyReports     WeeklyReport[]
  weightPredictions WeightPrediction[]
}

model DayPlan {
  id        String   @id @default(cuid())
  userId    String
  date      DateTime @db.Date
  carbType  CarbType
  calories  Int
  carb      Int
  protein   Int
  fat       Int
  completed Boolean  @default(false)
  muscleGroup   String?
  trainingLabel String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId])
}

model ChatMessage {
  id        String   @id @default(cuid())
  userId    String?
  role      ChatRole
  content   String   @db.Text
  cards     Json?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model WeightEntry {
  id        String   @id @default(cuid())
  userId    String
  date      DateTime @db.Date
  weight    Float
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId])
}

model MealLog {
  id          String   @id @default(cuid())
  userId      String
  date        DateTime @db.Date
  mealType    String
  description String   @db.Text
  items       Json
  carb        Float
  protein     Float
  fat         Float
  calories    Int?
  source      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
}

model DailyReport {
  id          String   @id @default(cuid())
  userId      String
  date        DateTime @db.Date
  score       Int
  summary     String   @db.Text
  suggestions Json
  readAt      DateTime?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId])
}

model WeeklyReport {
  id          String   @id @default(cuid())
  userId      String
  weekIndex   Int
  startDate   DateTime @db.Date
  endDate     DateTime @db.Date
  score       Int
  summary     String   @db.Text
  suggestions Json
  metrics     Json
  risks       Json
  readAt      DateTime?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, weekIndex])
  @@index([userId])
}

model WeightPrediction {
  id                     String   @id @default(cuid())
  userId                 String
  generatedAt            DateTime @default(now())
  currentWeight           Float
  goalWeight              Float
  estimatedGoalDate       DateTime? @db.Date
  estimatedDaysToGoal     Int?
  goalProbability         Int
  slopeKgPerDay           Float
  residualStd             Float
  plateauStatus           String
  plateauReason           String   @db.Text
  calorieDeficitSummary   Json
  forecast30Days          Json
  modelVersion            String   @default("linear-regression-v1")
  createdAt               DateTime @default(now())
  user                    User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, generatedAt])
}
